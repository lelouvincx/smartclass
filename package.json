{
  "name": "smartclass",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:worker": "vitest run --config vitest.worker-unit.config.js",
    "test:worker:watch": "vitest --config vitest.worker-unit.config.js",
    "test:integration": "vitest run --config vitest.worker.config.js",
    "test:integration:watch": "vitest --config vitest.worker.config.js",
    "preview": "vite preview",
    "deploy:web": "vite build && wrangler pages deploy dist --project-name smartclass",
    "deploy:api": "wrangler deploy",
    "deploy": "npm run deploy:api && npm run deploy:web",
    "cf:typegen": "wrangler types",
    "db:docs": "dbdocs build docs/schema.dbml --project smartclass"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.7.2",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^4.10.38",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@dbml/cli": "^6.4.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "dbdocs": "^1.1.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.8.1",
    "vite": "^6.0.5",
    "vitest": "~3.2.0",
    "wrangler": "^4.8.0"
  }
}
